        "jsCode": "// Keep top 10 articles\nconst articles = items.slice(0, 10);\n\nlet newsletterInput = '';\n\narticles.forEach((item, index) => {\n  newsletterInput += `\nArticle ${index + 1}\n\nTitle:\n${item.json.title}\n\nSummary:\n${item.json.contentSnippet}\n\n--------------------------------------------------\n\n`;\n});\n\nreturn [\n  {\n    json: {\n      newsletterInput\n    }\n  }\n];"
      },
